# Atlas edition — environment. Copy to `.env` and fill in. NEVER commit `.env`.
# The run scripts read process.env directly (no auto dotenv), so export these before running, e.g.:
#   set -a; source .env; set +a
# Every var below is optional except a subject key + (for judging) a judge model id + key.

# ─────────────────────────────────────────────────────────────────────────────
# Subject-under-test model (the model both arms drive)
# ─────────────────────────────────────────────────────────────────────────────
MODEL_ID=gemini-3.1-flash-lite       # subject model id
# PROVIDER=google                    # google | openai-compatible (inferred if unset)
THINKING=off                         # off | low | medium | high
# TEMPERATURE=                       # google: unset (API default) · openai-compatible: 0
# MAX_OUTPUT=2048                    # max output tokens

# — Option A: Google Gemini (the published cloud subject) —
GOOGLE_GENERATIVE_AI_API_KEY=        # your Google AI Studio key

# — Option B: any OpenAI-compatible endpoint (local llama.cpp / vLLM / ollama, or a hosted API) —
# PROVIDER=openai-compatible
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_API_KEY=not-needed          # or your key
# MODEL_ID=<the served model id>

# ─────────────────────────────────────────────────────────────────────────────
# Judge model (grades the run — the only quality verdict)
# ─────────────────────────────────────────────────────────────────────────────
# JUDGE_PROVIDER=anthropic           # anthropic | openai (inferred from keys if unset)
JUDGE_MODEL_ID=                      # judge model id (required to judge)
# — anthropic judge —
# ANTHROPIC_API_KEY=
# JUDGE_BASE_URL=https://api.anthropic.com
# — openai-compatible judge (incl. Gemini's OpenAI-compatible endpoint) —
# JUDGE_OPENAI_BASE_URL=https://api.openai.com/v1
# JUDGE_API_KEY=
# JUDGE_CONCURRENCY=4                # parallel judge calls
# VANILLA_MAX_STEPS=16              # ungoverned arm step budget

# ─────────────────────────────────────────────────────────────────────────────
# Optional: point the harness at a different edition's artifacts (defaults resolve in-edition)
# ─────────────────────────────────────────────────────────────────────────────
# SPECS_BUNDLE=                      # governed spec bundle (exports SPECS + THEME)
# SUBJECT_DIR=                       # subject dir (world + tools + cases + judge-prompt.md)
# VANILLA_BUNDLE=                    # ungoverned control bundle (exports AGENTS)
