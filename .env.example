# Copy to .env and fill in. NEVER commit .env.
# Google key for the gemini-flash-lite subject + the agentspec measured-loop / user-simulator.
# Use a project key here — do NOT rely on a global GEMINI_API_KEY in your shell.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional llama.cpp overrides (see docs/guides/llama-serving.md). Defaults resolve
# $LLAMA_BIN -> ~/llamacpp-b9780/bin/llama-server -> PATH.
# LLAMA_BIN=
# LLAMA_SLOT_SAVE_PATH=
